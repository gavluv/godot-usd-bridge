{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 26, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-base",
      "hidden": true,
      "description": "Shared Windows config. Pins the four load-bearing godot-cpp options.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "GODOTCPP_API_VERSION": "4.6",
        "GODOTCPP_USE_STATIC_CPP": "OFF",
        "GODOTCPP_DISABLE_EXCEPTIONS": "OFF",
        "CMAKE_PREFIX_PATH": "${sourceDir}/thirdparty/usd-install"
      }
    },
    {
      "name": "windows-debug",
      "inherits": "windows-base",
      "cacheVariables": { "GODOTCPP_TARGET": "template_debug" }
    },
    {
      "name": "windows-release",
      "inherits": "windows-base",
      "cacheVariables": { "GODOTCPP_TARGET": "template_release" }
    },
    {
      "name": "windows-tooling",
      "inherits": "windows-base",
      "description": "IDE tooling only: emits compile_commands.json for clangd. NOT for building (use windows-debug/release). Generate via scripts/gen_compile_commands.ps1.",
      "generator": "Ninja",
      "architecture": { "value": "x64", "strategy": "external" },
      "binaryDir": "${sourceDir}/build/tooling",
      "cacheVariables": {
        "GODOTCPP_TARGET": "template_debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    }
  ]
}
